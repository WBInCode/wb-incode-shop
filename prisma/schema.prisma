generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Product {
  id             String    @id @default(cuid())
  slug           String    @unique
  namePl         String
  nameEn         String
  descriptionPl  String
  descriptionEn  String
  categoryPl     String
  categoryEn     String
  technologies   String    @default("[]") // JSON array string
  screenshots    String    @default("[]") // JSON array string
  videoUrl       String?   // YouTube/Vimeo embed URL or direct video URL
  fileUrl        String
  featured       Boolean   @default(false)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  variants       Variant[]
  orders         Order[]
  addons         Addon[]
}

model Variant {
  id             String   @id @default(cuid())
  productId      String
  namePl         String
  nameEn         String
  descriptionPl  String
  descriptionEn  String
  price          Int      // price in grosze (PLN cents)
  currency       String   @default("PLN")
  active         Boolean  @default(true)

  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders         Order[]
}

model Order {
  id                String      @id @default(cuid())
  email             String
  productId         String
  variantId         String
  userId            String?
  amount            Int         // amount in grosze
  currency          String      @default("PLN")
  status            OrderStatus @default(PENDING)
  stripeSessionId   String?     @unique
  downloadToken     String      @unique
  invoiceCreated    Boolean     @default(false)
  wantInvoice       Boolean     @default(false)
  isCompany         Boolean     @default(true)
  companyName       String?
  companyNip        String?
  companyAddress    String?
  personName        String?
  personAddress     String?
  createdAt         DateTime    @default(now())

  product           Product     @relation(fields: [productId], references: [id])
  variant           Variant     @relation(fields: [variantId], references: [id])
  user              User?       @relation(fields: [userId], references: [id])
  orderAddons       OrderAddon[]
}

model Addon {
  id            String   @id @default(cuid())
  productId     String
  namePl        String
  nameEn        String
  descriptionPl String?
  descriptionEn String?
  price         Int      // price in grosze
  originalPrice Int?     // original (crossed-out) price in grosze
  currency      String   @default("PLN")
  required      Boolean  @default(false)
  badgePl       String?
  badgeEn       String?
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderAddons   OrderAddon[]
}

model OrderAddon {
  id      String @id @default(cuid())
  orderId String
  addonId String
  price   Int    // price at time of order

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addon   Addon  @relation(fields: [addonId], references: [id])
}

model Admin {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          AdminRole @default(ADMIN)
  createdAt     DateTime  @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "product.create", "order.paid", "user.delete"
  entity      String   // e.g. "product", "order", "user"
  entityId    String?  // ID of the affected record
  actor       String   // email or "system" for webhooks
  actorType   String   @default("admin") // "admin", "system", "customer"
  details     String   @default("{}") // JSON with changed fields / extra info
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([actor])
  @@index([createdAt])
}
